{
  "outputDirectory": "dist",
  "functions": {
    "api/ssr.ts": {
      "includeFiles": "dist/**, firebase-applet-config.json, firebase.json"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/",
      "destination": "/api/ssr"
    },
    {
      "source": "/((?!assets/|favicon.ico|robots.txt|sitemap.xml).*)",
      "destination": "/api/ssr"
    }
  ]
}
